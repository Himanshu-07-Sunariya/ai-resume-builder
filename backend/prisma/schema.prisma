generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}


model Resume {
  id         Int      @id @default(autoincrement())
  title      String

  firstName  String
  lastName   String

  email      String
  phone      String

  summary    String?

  educations Education[]

  experiences Experience[]

  projects Project[]

  skills Skill[]

  createdAt  DateTime @default(now())
}

model Education {
  id          Int      @id @default(autoincrement())

  institution String
  degree      String
  field       String

  startYear   Int
  endYear     Int

  resumeId    Int

  resume      Resume   @relation(fields: [resumeId], references: [id])

  createdAt   DateTime @default(now())
}

model Experience {
  id          Int      @id @default(autoincrement())

  company     String
  role        String
  description String

  startDate   String
  endDate     String

  resumeId    Int

  resume      Resume @relation(fields: [resumeId], references: [id])

  createdAt   DateTime @default(now())
}

model Project {
  id          Int      @id @default(autoincrement())

  title       String
  description String

  githubLink  String?
  liveLink    String?

  resumeId    Int

  resume      Resume @relation(fields: [resumeId], references: [id])

  createdAt   DateTime @default(now())
}

model Skill {
  id        Int      @id @default(autoincrement())

  name      String

  resumeId  Int

  resume    Resume @relation(fields: [resumeId], references: [id])

  createdAt DateTime @default(now())
}